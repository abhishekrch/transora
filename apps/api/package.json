{
  "name": "@transora/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@prisma/client": "^7.8.0",
    "@trpc/server": "^11.18.0",
    "bullmq": "^5.79.1",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@transora/shared": "workspace:*",
    "@transora/eslint-config": "workspace:*",
    "@transora/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
